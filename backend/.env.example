# Environment variables for CivicFix

# Copy this file to .env and configure

# Database Configuration
DATABASE_URL=postgresql://civicfix_user:changeme123@localhost:5432/civicfix

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@civicfix.local

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Application Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
DUPLICATE_RADIUS_METERS=100
